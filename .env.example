# Copy this file to .env and fill in real values. Do NOT commit .env.

# --- Supabase (app data, auth, realtime, storage) ---
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- Cal.com (self-hosted booking engine) ---
# Base URL of your self-hosted Cal.com instance and the astrologer's username,
# used to build embed links (e.g. https://cal.yourdomain.com / "dilip").
VITE_CALCOM_URL=https://your-calcom-instance.example.com
VITE_CALCOM_USERNAME=astrodilip

# --- Third-party astrology API (Reports page) ---
VITE_VEDIC_ASTRO_API_KEY=your_vedic_astro_api_key_here

# --- JyotishamAstroAPI (panchang, charts, dasha, etc.) ---
VITE_JYOTISHAM_API_KEY=your_jyotisham_astro_api_key_here

# --- Razorpay (DEFERRED - payments disabled for now) ---
# VITE_RAZORPAY_KEY_ID=your_public_razorpay_key_id
